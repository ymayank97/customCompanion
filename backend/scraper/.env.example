# Example environment configuration for customs data scraper
# Copy this file to .env and customize as needed

# ============================================================
# SCRAPING SETTINGS
# ============================================================

# Rate limiting (seconds between requests)
RATE_LIMIT_DELAY=2.0

# Request timeout (seconds)
REQUEST_TIMEOUT=30

# Maximum retries for failed requests
MAX_RETRIES=3

# User-Agent string
USER_AGENT="Mozilla/5.0 (compatible; CustomsClassifierBot/1.0; research purposes)"

# ============================================================
# DATA SOURCE URLS (customize if needed)
# ============================================================

ICEGATE_BASE_URL=https://old.icegate.gov.in/Webappl/
CBIC_NOTIFICATIONS_URL=https://www.cbic.gov.in/htdocs-cbec/customs/custom-tariff
INDIAN_TRADE_PORTAL_URL=https://www.indiantradeportal.in/

# ============================================================
# SCRAPING PARAMETERS
# ============================================================

# Default chapter range
DEFAULT_CHAPTER_START=1
DEFAULT_CHAPTER_END=99

# Default notification lookback period (days)
DEFAULT_NOTIFICATION_DAYS=90

# Enable/disable sources
ENABLE_ICEGATE=true
ENABLE_CBIC=true
ENABLE_INDIAN_PORTAL=false

# ============================================================
# DATABASE SETTINGS (optional)
# ============================================================

# Database URL (if using)
# DATABASE_URL=postgresql://user:password@localhost:5432/customs_db

# Or individual settings
DB_HOST=localhost
DB_PORT=5432
DB_NAME=customs_db
DB_USER=postgres
DB_PASSWORD=your_password_here

# Enable database logging
ENABLE_DB_LOGGING=false

# ============================================================
# LOGGING SETTINGS
# ============================================================

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Maximum log file size (MB)
MAX_LOG_SIZE_MB=100

# Number of backup log files to keep
LOG_BACKUP_COUNT=5

# ============================================================
# CACHE SETTINGS
# ============================================================

# Enable caching
ENABLE_CACHE=true

# Cache TTL (seconds) - 86400 = 24 hours
CACHE_TTL=86400

# ============================================================
# PDF PROCESSING
# ============================================================

# Maximum PDF size to process (MB)
MAX_PDF_SIZE_MB=50

# Extract images from PDFs
PDF_EXTRACT_IMAGES=false

# Context window for CTH extraction (characters)
CTH_CONTEXT_CHARS=50

# ============================================================
# PLAYWRIGHT SETTINGS (for JavaScript-heavy sites)
# ============================================================

# Browser type (chromium, firefox, webkit)
PLAYWRIGHT_BROWSER=chromium

# Run in headless mode
PLAYWRIGHT_HEADLESS=true

# Page load timeout (milliseconds)
PLAYWRIGHT_TIMEOUT=30000

# ============================================================
# DATA VALIDATION
# ============================================================

# Validate CTH code format
VALIDATE_CTH_FORMAT=true

# Minimum description length
MIN_DESCRIPTION_LENGTH=10

# Skip incomplete entries
SKIP_INCOMPLETE_ENTRIES=true

# ============================================================
# EXPORT SETTINGS
# ============================================================

# Default export format (json, csv, both)
DEFAULT_EXPORT_FORMAT=both

# Include metadata in exports
INCLUDE_METADATA=true

# JSON indentation level
JSON_INDENT=2

# CSV delimiter
CSV_DELIMITER=,

# ============================================================
# SCHEDULING (optional)
# ============================================================

# Enable scheduled scraping
ENABLE_SCHEDULER=false

# Schedule time (24-hour format)
SCHEDULE_TIME=02:00

# Days of week to run (0=Monday, 6=Sunday)
SCHEDULE_DAYS=0,1,2,3,4

# ============================================================
# NOTIFICATIONS (optional)
# ============================================================

# Email notifications
ENABLE_EMAIL_NOTIFICATIONS=false
EMAIL_TO=your-email@example.com
EMAIL_FROM=scraper@example.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASSWORD=your-smtp-password

# Slack notifications
ENABLE_SLACK_NOTIFICATIONS=false
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ============================================================
# DEVELOPMENT/DEBUG
# ============================================================

# Debug mode
DEBUG=false

# Dry run (don't save data)
DRY_RUN=false

# Test mode (limited scraping)
TEST_MODE=false
TEST_CHAPTER_LIMIT=5
TEST_NOTIFICATION_LIMIT=10

# Save raw HTML for debugging
SAVE_RAW_HTML=false
